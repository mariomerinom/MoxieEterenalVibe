# ── Ethereum L1 — OWN GETH NODE ON OVH ──
# Production: set up an SSH tunnel or WireGuard from this host to
# 162.19.138.15, then point at localhost. Geth RPC is bound to 127.0.0.1
# on the OVH server (not exposed to the internet).
#
# SSH tunnel command (run in a separate terminal or via autossh):
#   ssh -N -L 8545:127.0.0.1:8545 -L 8546:127.0.0.1:8546 ubuntu@162.19.138.15
#
ETH_RPC_HTTP=http://127.0.0.1:8545
ETH_RPC_WS=ws://127.0.0.1:8546

# ── L2s and alt chains ──
# Only needed if validating strategies on those chains. All Phase 6 L2
# strategies were killed — these are optional. Use any free public RPC
# (publicnode.com, ankr, llamarpc) or self-host if needed.
BASE_RPC_HTTP=https://base.llamarpc.com
BASE_RPC_WS=wss://base-rpc.publicnode.com

ARB_RPC_HTTP=https://arbitrum.llamarpc.com
ARB_RPC_WS=wss://arbitrum-one-rpc.publicnode.com

POLYGON_RPC_HTTP=https://polygon.llamarpc.com
POLYGON_RPC_WS=wss://polygon-bor-rpc.publicnode.com

SCROLL_RPC_HTTP=https://rpc.scroll.io
SCROLL_RPC_WS=wss://scroll-mainnet-public.unifra.io

BLAST_RPC_HTTP=https://rpc.blast.io
BLAST_RPC_WS=wss://blast-rpc.publicnode.com

# Solana (killed at B1; keep only if revisiting with live pool-state probe)
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com

# ── Auth / keys ──
# Flashbots bundle signing (Phase 3 — sandwich execution)
FLASHBOTS_SIGNING_KEY=

# EigenPhi ground-truth API (optional, for backtesting)
EIGENPHI_API_KEY=

# ── Logging ──
RUST_LOG=info,mev_capture=debug,mev_analysis=debug
